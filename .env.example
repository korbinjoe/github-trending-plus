# Postgres (local: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_trending

# GitHub GraphQL (server-side only)
GITHUB_TOKEN=ghp_your_token_here

# Cron route protection
CRON_SECRET=generate_a_long_random_string

# Public site URL (RSS links, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Product Hunt API (server-side only; app: github-trending-plus)
# Option A: OAuth app key + secret (client credentials)
PRODUCTHUNT_API_KEY=
PRODUCTHUNT_API_SECRET=
# Option B: Developer Token from https://www.producthunt.com/v2/oauth/applications (overrides A)
# PRODUCTHUNT_DEVELOPER_TOKEN=
# PH_INGEST_LOOKBACK_DAYS=7
# PH_INGEST_TOPICS=developer-tools,open-source
# PH_INGEST_PAGE_SIZE=50
